{
  "expo": {
    "name": "smartStack",
    "slug": "smartstack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartstack.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F0FF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.smartstack.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      ["expo-camera", { "cameraPermission": "Allow smartStack to access your camera." }],
      ["expo-location", { "locationAlwaysAndWhenInUsePermission": "Allow smartStack to use your location." }]
    ],
    "scheme": "smartstack"
  }
}
